{
  "version": 2,
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/index.js"
    }
  ],
  "env": {
    "REDIS_HOST": "@redis-host",
    "REDIS_PORT": "@redis-port",
    "REDIS_USERNAME": "@redis-username",
    "REDIS_PASSWORD": "@redis-password"
  }
}
